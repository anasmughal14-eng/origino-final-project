# ORIGINO environment template
# Local development can use NEXT_PUBLIC_USE_MOCK_DATA=true.
# Production should use NEXT_PUBLIC_USE_MOCK_DATA=false after Supabase schema + seed are ready.

# App
NEXT_PUBLIC_APP_URL=https://origino.store
NEXT_PUBLIC_SITE_URL=https://origino.store
NEXT_PUBLIC_USE_MOCK_DATA=true
NEXT_PUBLIC_WHATSAPP_NUMBER=923324823947
CRON_SECRET=replace-with-long-random-secret

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI audit engine
# Used server-side only by /api/submit-audit. Do not expose this as NEXT_PUBLIC_*.
GEMINI_API_KEY=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=noreply@origino.store
NOTIFICATION_EMAIL=origino.pk@gmail.com

# Stripe
# Parked until provider approval. Keep false until live credentials + webhook QA are complete.
ENABLE_STRIPE_PAYMENTS=false
ENABLE_STRIPE_CONNECT=false
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=

# JazzCash
# Parked until provider approval. Keep false until sandbox/live verification is complete.
ENABLE_LOCAL_PAYMENTS=false
JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
JAZZCASH_INTEGRITY_SALT=
JAZZCASH_API_URL=https://payments.jazzcash.com.pk/ApplicationAPI/API

# EasyPaisa
EASYPAISA_STORE_ID=
EASYPAISA_HASH_KEY=
EASYPAISA_API_URL=https://easypay.easypaisa.com.pk

# Exchange rates
OPEN_EXCHANGE_RATES_APP_ID=

# Sanctions screening
SANCTIONS_CHECK_API_KEY=
SANCTIONS_API_URL=

# Analytics and monitoring
NEXT_PUBLIC_POSTHOG_KEY=
SENTRY_DSN=

# Upstash Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Video, logistics, and API security
DAILY_CO_API_KEY=
AFTERSHIP_API_KEY=
API_KEY_SALT=
